# Copy to `.env.prod` ON THE VPS and fill with real values. Do NOT commit .env.prod.
# Consumed by: docker compose -f docker-compose.prod.yml --env-file .env.prod up -d --build

# Strong Postgres password (internal-only; Postgres is never published to the host).
DB_PASSWORD=REPLACE_WITH_A_STRONG_DB_PASSWORD

# API key the frontend + agent must send as `x-api-key`. NOTE: the frontend embeds this
# in its JS bundle, so it is a light gate, not a true secret (see DEPLOY.md security note).
API_KEY=REPLACE_WITH_A_STRONG_API_KEY

# Public hostname for the API. nip.io/sslip.io resolve automatically to the embedded IP.
API_DOMAIN=156-67-105-74.nip.io
